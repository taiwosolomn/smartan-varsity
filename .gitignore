# ─────────────────────────────────────────────────────────────────────────────
#  STA Learning OS — Root .gitignore
#  Covers: frontend (Vite/React), backend (FastAPI/Python), OS & editor junk
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment / Secrets ─────────────────────────────────────────────────────
# NEVER commit .env files — rotate any key that was already committed.
.env
.env.local
.env.production
.env.staging
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.*.local
backend/.env
backend/.env.local

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/
frontend/build/
.vite/
frontend/.vite/
dist-ssr/

# ── Python / Backend ─────────────────────────────────────────────────────────
__pycache__/
backend/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
backend/venv/
backend/.venv/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor junk ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Build / Cache ─────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
coverage/
.nyc_output/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.tox/
.hypothesis/
instance/

# ── Misc project-specific ─────────────────────────────────────────────────────
